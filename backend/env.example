# ZMQ Transport Configuration for Distributed SDR Deployment
# Copy to .env and customize for your deployment
# Load with: export $(cat .env | xargs) && python backend/Interference.py

# Deployment Mode
LOCAL_MODE=true
REMOTE_MODE=false

# ZMQ Endpoints (GNU Radio ZMQ PUB Sinks)
SCIPY_ZMQ_IQ_ADDR=tcp://127.0.0.1:5555
SCIPY_ZMQ_META_ADDR=tcp://127.0.0.1:5556
SCIPY_ZMQ_CARRIER_ADDR=tcp://127.0.0.1:5557

# Example: Distributed Deployment (Raspberry Pi + Backend Server)
# REMOTE_MODE=true
# SCIPY_ZMQ_IQ_ADDR=tcp://192.168.1.20:5555
# SCIPY_ZMQ_META_ADDR=tcp://192.168.1.20:5556
# SCIPY_ZMQ_CARRIER_ADDR=tcp://192.168.1.20:5557

# Headless Mode (Server Deployment)
SCIPY_HEADLESS=0

# Snapshot API Configuration
SCIPY_SNAPSHOT_PORT=8766
SCIPY_API_HOST=0.0.0.0  # Bind to all interfaces (allows remote frontend access)
                        # Use 127.0.0.1 for localhost-only access

# Active Antenna Configuration
SCIPY_ACTIVE_ANTENNA=gsat-30
