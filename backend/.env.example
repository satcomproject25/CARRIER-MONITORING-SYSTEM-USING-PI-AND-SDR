# =============================================================================
# ZMQ Transport Configuration — Distributed SDR Deployment
# =============================================================================
# Copy this file to .env and customize for your deployment
# Load with: export $(cat .env | xargs) && python backend/Interference.py
# =============================================================================

# -----------------------------------------------------------------------------
# DEPLOYMENT MODE
# -----------------------------------------------------------------------------
# LOCAL_MODE=true   → Use localhost endpoints (single-machine deployment)
# REMOTE_MODE=true  → Use environment-configured endpoints (distributed)
# -----------------------------------------------------------------------------
LOCAL_MODE=true
REMOTE_MODE=false

# -----------------------------------------------------------------------------
# ZMQ ENDPOINTS — GNU Radio ZMQ PUB Sinks
# -----------------------------------------------------------------------------
# These endpoints must match the GNU Radio flowgraph ZMQ PUB Sink addresses.
# GNU Radio BINDS (server), Interference.py CONNECTS (client).
#
# Local deployment:  tcp://127.0.0.1:PORT
# Remote deployment: tcp://RASPBERRY_PI_IP:PORT
# -----------------------------------------------------------------------------

# IQ stream endpoint (complex64 samples from SDR)
SCIPY_ZMQ_IQ_ADDR=tcp://127.0.0.1:5555

# Metadata stream endpoint (sample rate, FFT size, center frequency updates)
SCIPY_ZMQ_META_ADDR=tcp://127.0.0.1:5556

# Carrier hints endpoint (optional carrier list from external detector)
SCIPY_ZMQ_CARRIER_ADDR=tcp://127.0.0.1:5557

# -----------------------------------------------------------------------------
# EXAMPLE: Distributed Deployment (Raspberry Pi + Backend Server)
# -----------------------------------------------------------------------------
# Raspberry Pi IP: 192.168.1.20
# Backend Server IP: 192.168.1.100
#
# On Raspberry Pi (GNU Radio):
#   - Edit sdr_scipy.grc: set ZMQ address to tcp://0.0.0.0:5555
#   - Run: python3 sdr_scipy.py
#
# On Backend Server (Interference.py):
#   - Uncomment lines below and set REMOTE_MODE=true
# -----------------------------------------------------------------------------
# REMOTE_MODE=true
# SCIPY_ZMQ_IQ_ADDR=tcp://192.168.1.20:5555
# SCIPY_ZMQ_META_ADDR=tcp://192.168.1.20:5556
# SCIPY_ZMQ_CARRIER_ADDR=tcp://192.168.1.20:5557

# -----------------------------------------------------------------------------
# HEADLESS MODE (Server Deployment)
# -----------------------------------------------------------------------------
# SCIPY_HEADLESS=1  → No matplotlib/Qt GUI, Flask API only
# SCIPY_HEADLESS=0  → Desktop mode with live spectrum plot
# -----------------------------------------------------------------------------
SCIPY_HEADLESS=0

# -----------------------------------------------------------------------------
# SNAPSHOT API PORT (Headless Mode)
# -----------------------------------------------------------------------------
# Flask API port for /api/snapshot endpoint (frontend data source)
# -----------------------------------------------------------------------------
SCIPY_SNAPSHOT_PORT=8766

# -----------------------------------------------------------------------------
# ACTIVE ANTENNA CONFIGURATION
# -----------------------------------------------------------------------------
# Antenna ID for authorized frequency lookup
# Must match an entry in backend/authorized_freqs.json
# -----------------------------------------------------------------------------
SCIPY_ACTIVE_ANTENNA=gsat-30

# -----------------------------------------------------------------------------
# NETWORK TROUBLESHOOTING
# -----------------------------------------------------------------------------
# If experiencing connection issues:
#
# 1. Verify GNU Radio is running:
#    ps aux | grep sdr_scipy
#
# 2. Check ZMQ binding:
#    netstat -tuln | grep 5555
#
# 3. Test network connectivity:
#    ping 192.168.1.20
#
# 4. Check firewall rules:
#    sudo ufw status
#
# 5. Monitor ZMQ logs:
#    python backend/Interference.py 2>&1 | grep ZMQ
# -----------------------------------------------------------------------------